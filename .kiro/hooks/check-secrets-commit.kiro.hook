{
  "name": "Scan for Secrets Before Commit",
  "version": "1.0.0",
  "description": "Scans staged files for API keys, tokens, passwords, and .env values before git commit to prevent accidental secret exposure.",
  "when": {
    "type": "preToolUse",
    "toolTypes": [".*git.*commit.*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A git commit is about to be made. Scan the staged changes for potential secrets: API keys (ELEVENLABS_API_KEY, GEMINI_API_KEY, SUPABASE_SERVICE_ROLE_KEY), tokens, passwords, private keys, or .env file contents. Also check that no files from .claude/ or .remember/ directories are being committed. If any secrets or excluded files are detected, DENY the commit and explain what was found. If clean, allow it to proceed."
  }
}